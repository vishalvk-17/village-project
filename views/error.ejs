<%- layout("/layouts/boilerplate") %>

<section class="py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm text-center p-4 p-md-5">
        <span class="home-section-tag mx-auto mb-3">Error <%= statusCode %></span>
        <h1 class="section-title mb-3"><%= title %></h1>
        <p class="lead text-muted mb-4"><%= message %></p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
          <a href="/" class="btn btn-primary">Go To Home</a>
          <a href="/villagers" class="btn btn-outline-primary">Browse Villagers</a>
        </div>
      </div>
    </div>
  </div>
</section>
