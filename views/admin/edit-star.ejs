<%- layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
          <h2 class="text-success mb-3">Edit Village Star</h2>
          <p class="text-muted mb-4">Gaon ke sitare ki information update karo. Yeh change homepage par reflect hoga.</p>

          <form action="/admin/stars/<%= star._id %>?_method=PUT" method="POST">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input type="text" name="name" class="form-control" value="<%= star.name %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Title</label>
              <input type="text" name="title" class="form-control" value="<%= star.title %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea name="description" rows="5" class="form-control" required><%= star.description %></textarea>
            </div>

            <div class="mb-3">
              <label class="form-label">Image URL</label>
              <input type="text" name="imageUrl" class="form-control" value="<%= star.imageUrl || '' %>">
            </div>

            <div class="mb-4">
              <label class="form-label">Accent Class</label>
              <input type="text" name="accentClass" class="form-control" value="<%= star.accentClass || '' %>">
            </div>

            <div class="d-flex gap-3 flex-wrap">
              <button class="btn btn-success">Update Star</button>
              <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
