<%- layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
          <h2 class="text-primary mb-3">Edit Notice</h2>
          <p class="text-muted mb-4">Notice ki details update karo. Save karte hi home page par naya content dikhne lagega.</p>

          <form action="/admin/notices/<%= notice._id %>?_method=PUT" method="POST">
            <div class="mb-3">
              <label class="form-label">Title</label>
              <input type="text" name="title" class="form-control" value="<%= notice.title %>" required>
            </div>

            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea name="description" rows="5" class="form-control" required><%= notice.description %></textarea>
            </div>

            <div class="mb-4">
              <label class="form-label">Bootstrap Icon Class</label>
              <input type="text" name="iconClass" class="form-control" value="<%= notice.iconClass || '' %>">
            </div>

            <div class="d-flex gap-3 flex-wrap">
              <button class="btn btn-primary">Update Notice</button>
              <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
