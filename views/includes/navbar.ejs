<header class="cc-nav-shell">
  <nav class="cc-navbar navbar navbar-expand-lg">
    <div class="cc-container">
      <div class="cc-navbar__panel">
        <a class="navbar-brand cc-brand d-flex align-items-center gap-3 m-0" href="/" aria-label="Home">
          <span class="cc-brand__crest">
            <i class="bi bi-buildings-fill"></i>
          </span>
          <span>
            <span class="cc-brand__eyebrow">Village Portal</span>
            <span class="cc-brand__title">भिलखेड़ा गांव</span>
          </span>
        </a>

        <div class="d-none d-lg-flex align-items-center gap-3">
          <div class="cc-nav-links">
            <a href="/" class="cc-link">होम</a>
            <a href="/villagers" class="cc-link">गांववासी</a>
            <a href="/families" class="cc-link">Families</a>
            <a href="/community" class="cc-link">संगठन</a>
            <a href="/about" class="cc-link">About</a>
            <a href="#contact" class="cc-link">संपर्क</a>
          </div>

          <div class="cc-nav-actions">
            <% if (!currentUser) { %>
              <a href="/register" class="cc-action-btn cc-action-btn--ghost">Register</a>
              <a href="/login" class="cc-action-btn cc-action-btn--solid">Login</a>
            <% } else { %>
              <div class="cc-user-chip">
                <span class="cc-user-chip__dot"></span>
                <span><%= currentUser.role === "admin" ? "Admin" : "Member" %></span>
              </div>
              <% if (currentUser.role === "admin") { %>
                <a href="/admin" class="cc-action-btn cc-action-btn--ghost">Admin Panel</a>
              <% } %>
              <a href="/logout" class="cc-action-btn cc-action-btn--solid">Logout</a>
            <% } %>
          </div>
        </div>

        <button
          class="navbar-toggler cc-menu-toggle d-lg-none"
          type="button"
          data-bs-toggle="offcanvas"
          data-bs-target="#mobileMenu"
          aria-controls="mobileMenu"
          aria-label="Open menu"
        >
          <i class="bi bi-list"></i>
        </button>
      </div>
    </div>
  </nav>
</header>

<div class="offcanvas offcanvas-end cc-canvas" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
  <div class="offcanvas-header align-items-start">
    <div>
      <p class="cc-offcanvas__eyebrow mb-1">Navigation</p>
      <h5 class="offcanvas-title fw-semibold mb-0" id="mobileMenuLabel">भिलखेड़ा गांव</h5>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>

  <div class="offcanvas-body pt-0">
    <% if (currentUser) { %>
      <div class="cc-mobile-user mb-4">
        <span class="cc-user-chip__dot"></span>
        <div>
          <strong class="d-block"><%= currentUser.role === "admin" ? "Admin Account" : "Community Member" %></strong>
          <small><%= currentUser.role === "admin" ? "Manage notices, stars and approvals" : "Browse village people and families" %></small>
        </div>
      </div>
    <% } %>

    <div class="cc-mobile-links">
      <a href="/" class="cc-mobile-link">
        <span>होम</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
      <a href="/villagers" class="cc-mobile-link">
        <span>गांववासी</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
      <a href="/families" class="cc-mobile-link">
        <span>Families</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
      <a href="/community" class="cc-mobile-link">
        <span>संगठन</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
      <a href="/about" class="cc-mobile-link">
        <span>About</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
      <a href="#contact" class="cc-mobile-link">
        <span>संपर्क</span>
        <i class="bi bi-arrow-up-right"></i>
      </a>
    </div>

    <div class="cc-mobile-actions">
      <% if (!currentUser) { %>
        <a href="/register" class="cc-action-btn cc-action-btn--ghost w-100 text-center">Register</a>
        <a href="/login" class="cc-action-btn cc-action-btn--solid w-100 text-center">Login</a>
      <% } else { %>
        <% if (currentUser.role === "admin") { %>
          <a href="/admin" class="cc-action-btn cc-action-btn--ghost w-100 text-center">Admin Panel</a>
        <% } %>
        <a href="/logout" class="cc-action-btn cc-action-btn--solid w-100 text-center">Logout</a>
      <% } %>
    </div>
  </div>
</div>
