<%- layout("/layouts/boilerplate") %>

<section class="family-directory py-5">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h2 class="mb-2">Village Families Directory</h2>
      <p class="text-muted mb-0">Explore households, villages, and linked members in one place.</p>
    </div>
    <% if (currentUser) { %>
      <a href="/families/new" class="btn btn-primary">Add New Family</a>
    <% } %>
  </div>

  <form action="/families" method="GET" class="card border-0 shadow-sm p-3 p-md-4 mb-4 family-search-form">
    <div class="row g-3 align-items-end">
      <div class="col-md-9">
        <label for="search" class="form-label">Search Families</label>
        <input
          type="text"
          id="search"
          name="search"
          value="<%= search || '' %>"
          class="form-control"
          placeholder="Search by family head, village, or district"
        >
      </div>
      <div class="col-md-3 d-grid">
        <button class="btn btn-outline-primary">Search</button>
      </div>
    </div>
  </form>

  <% if (families.length === 0) { %>
    <div class="alert alert-warning text-center shadow-sm">
      No family records found yet.
    </div>
  <% } else { %>
    <div class="row g-4">
      <% for (let family of families) { %>
        <div class="col-lg-4 col-md-6">
          <div class="card h-100 border-0 shadow-sm family-card">
            <div class="card-body p-4">
              <div class="family-card__icon mb-3">
                <i class="bi bi-house-heart-fill"></i>
              </div>
              <h4 class="mb-2"><%= family.headName %></h4>
              <p class="text-muted mb-3">
                <%= family.address?.village || "Bhilkheda" %>
                <% if (family.address?.district) { %>
                  , <%= family.address.district %>
                <% } %>
              </p>

              <div class="family-card__meta">
                <p><strong>Members:</strong> <%= family.members?.length || 0 %></p>
                <p><strong>Address:</strong> <%= family.address?.line1 || "Address not added" %></p>
                <p><strong>State:</strong> <%= family.address?.state || "N/A" %></p>
              </div>

              <% if (family.familyNote) { %>
                <p class="text-muted small mt-3 mb-4"><%= family.familyNote.length > 110 ? `${family.familyNote.slice(0, 110)}...` : family.familyNote %></p>
              <% } %>

              <a href="/families/<%= family._id %>" class="btn btn-outline-primary w-100">View Family</a>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</section>
