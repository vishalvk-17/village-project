<%- layout("/layouts/boilerplate") %>

<body>
    <h2>Family Details</h2>
    <p><strong>Head Name:</strong> <%= family.headName %></p>

    <h3>Address:</h3>
    <p><%= family.address.line1 %></p>
    <p>Village: <%= family.address.village %></p>
    <p>District: <%= family.address.district %></p>
    <p>State: <%= family.address.state %></p>
    <p>Pincode: <%= family.address.pincode %></p>
    <br>
    <a href="/families/<%= family._id %>/edit"> update Family</a>
    <br>
    <!-- Delete Form -->
    <form action="/families/<%= family._id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this family?');">
            🗑️ Delete
        </button>
    </form>
    <br>
    <a href="/families">🔙 Back to Families</a>
</body>