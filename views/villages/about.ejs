<%- layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h1 class="fw-bold text-primary">About Us</h1>
    <p class="lead text-muted">
      Yeh website village community ko digital tareeke se jodne ke liye banayi gayi hai.
      Yahan villagers register kar sakte hain, profile bana sakte hain, aur admin notices aur gaon ke sitare manage kar sakta hai.
    </p>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100 text-center">
        <div class="card-body">
          <i class="bi bi-geo-alt fs-1 text-primary"></i>
          <h5 class="card-title mt-3">Our Address</h5>
          <p class="card-text">Bhilkheda, District Rajgarh, MP</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100 text-center">
        <div class="card-body">
          <i class="bi bi-envelope fs-1 text-primary"></i>
          <h5 class="card-title mt-3">Email Us</h5>
          <p class="card-text">contact@villageweb.com</p>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-0 h-100 text-center">
        <div class="card-body">
          <i class="bi bi-telephone fs-1 text-primary"></i>
          <h5 class="card-title mt-3">Call Us</h5>
          <p class="card-text">+91 9876543210</p>
        </div>
      </div>
    </div>
  </div>

  <div class="text-center mt-5">
    <a href="/" class="btn btn-outline-primary">Back to Home</a>
  </div>
</div>
