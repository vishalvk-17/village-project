<%- layout("/layouts/boilerplate") %>
<!-- home.ejs -->
<head>
    <style>
    body {
        background: #f9fafb;
        }
        .section-title {
        font-weight: bold;
        text-align: center;
        margin-bottom: 2rem;
        color: #2c3e50;
        }
        .notice-board {
        background: #fff;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .notice-item {
        border-bottom: 1px dashed #ddd;
        padding: 0.7rem 0;
        }
        .notice-item:last-child {
        border-bottom: none;
        }
        .gallery img {
        border-radius: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .gallery img:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }
        #developer .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        #developer .card:hover {
          transform: translateY(-10px);
          box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
    </style>
</head>
<body>

  <!-- Main Content -->
  <main class="container my-5">

    <!-- About Section -->
    <section class="mb-5 ">
      <h2 class="section-title">About Our Village</h2>
      <div class="row align-items-center ">
        <div class="col-md-6">
          <p class="lead">
            हमारा गाँव परंपराओं और संस्कृति से भरा हुआ है। यहाँ लोग मिलजुल कर रहते हैं और त्योहारों को बड़े उत्साह से मनाते हैं। 
            प्राकृतिक सुंदरता और स्वच्छ वातावरण इसे और भी खास बनाते हैं।
          </p>
        </div>
        <div class="col-md-6">
          <img src="https://images.unsplash.com/photo-1591883093451-83abd0f56a1f?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Village" class="img-fluid rounded shadow">
        </div>
      </div>
    </section>

    <!-- Notice Board -->
    <section class="mb-5">
      <h2 class="section-title">Notice Board</h2>
      <div class="notice-board">
        <div class="notice-item">
          <i class="bi bi-megaphone text-primary"></i> 🔱 मकर संक्रांति पर्व
14 जनवरी को ग्राम में मकर संक्रांति का पावन पर्व हर्षोल्लास के साथ मनाया जाएगा। सभी ग्रामवासी सपरिवार सम्मिलित हों।
        </div>
        <div class="notice-item">
          <i class="bi bi-calendar-event text-success"></i> 📿 प्रवचन / कथा कार्यक्रम
दिनांक 10 जनवरी से ग्राम में धार्मिक प्रवचन / कथा का आयोजन किया जाएगा। समय व स्थान की जानकारी शीघ्र दी जाएगी।
        </div>
        <div class="notice-item">
          <i class="bi bi-people-fill text-danger"></i> 🚩 हनुमान जी मंदिर यज्ञ
मार्च माह में हनुमान जी मंदिर में यज्ञ का आयोजन किया जाएगा। सभी श्रद्धालुओं से निवेदन है कि अधिक से अधिक संख्या में उपस्थित होकर पुण्य लाभ अर्जित करें।
        </div>
      </div>
    </section>

    <!-- Culture & Traditions -->
    <section class="mb-5">
      <h2 class="section-title">Culture & Traditions</h2>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <img src="https://plus.unsplash.com/premium_photo-1682090882077-31b6875e8822?q=80&w=998&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Festival">
            <div class="card-body">
              <h5 class="card-title">Festivals</h5>
              <p class="card-text">हमारे गाँव में दिवाली, होली और नवरात्रि बड़े हर्षोल्लास से मनाए जाते हैं।</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <img src="https://images.unsplash.com/photo-1723066217456-cf0b10ceda2b?q=80&w=1035&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Food">
            <div class="card-body">
              <h5 class="card-title">Traditional Food</h5>
              <p class="card-text">यहाँ की खासियत है देसी व्यंजन जैसे दाल-बाटी, पूड़ी और मिठाइयाँ।</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <img src="https://images.unsplash.com/photo-1717011969223-0217a302ec6f?q=80&w=986&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Dance">
            <div class="card-body">
              <h5 class="card-title">Folk Dance</h5>
              <p class="card-text">गाँव के लोग पारंपरिक नृत्यों और गीतों से त्योहारों को जीवंत बनाते हैं।</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    

<!-- Temples Section -->
    <section class="py-5 bg-light" id="temples">
  <div class="container">
    <h2 class="text-center mb-5 fw-bold">🙏 हमारे गाँव के मंदिर</h2>
    <div class="row g-4">
      
      <!-- Radha Krishna Temple -->
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
          <img src="https://plus.unsplash.com/premium_photo-1676111266437-027b26837de3?q=80&w=1287&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Radha Krishna Mandir">
          <div class="card-body">
            <h5 class="card-title text-danger fw-bold"><b>राधाकृष्ण मंदिर</b></h5>
            <p class="card-text">यह मंदिर हमारे गाँव का प्रमुख धार्मिक स्थल है जहाँ प्रतिदिन भजन और आरती होती है।</p>
            <p class="text-muted"><strong>समिति:</strong> राधाकृष्ण मंदिर समिति</p>
            <p class="card-text"><strong>समिति प्रमुख:</strong> बलराम राजपूत</p>
          </div>
        </div>
      </div>

      <!-- Shri Ram Temple -->
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
          <img src="https://images.unsplash.com/photo-1678593628844-6ea49dee8ce3?q=80&w=1287&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Shri Ram Mandir">
          <div class="card-body">
            <h5 class="card-title text-danger fw-bold"><b>श्रीराम मंदिर</b></h5>
            <p class="card-text">गाँव के मध्य स्थित यह मंदिर रामभक्तों का आस्था केंद्र है और रामनवमी विशेष उत्सव होता है।</p>
            <p class="text-muted"><strong>समिति:</strong> श्रीराम मंदिर समिति</p>
            <p class="card-text"><strong>समिति प्रमुख:</strong> देवेंद्र राजपूत</p>
          </div>
        </div>
      </div>

      <!-- Hanuman Temple -->
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0">
          <img src="https://images.unsplash.com/photo-1733396722075-0fc6e89efad9?q=80&w=1287&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Hanuman Mandir">
          <div class="card-body">
            <h5 class="card-title text-danger fw-bold"><strong>हनुमान मंदिर</strong></h5>
            <p class="card-text">यहाँ प्रत्येक मंगलवार और शनिवार को विशेष पूजा और भजन संध्या का आयोजन होता है।</p>
            <p class="text-muted"><strong>समिति:</strong> हनुमान मंदिर समिति</p>
            <p class="card-text"><b>समिति प्रमुख:</b> दिनेश योगी</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ====== Gaon Ke Sitare Section ====== -->
<section id="gaon-ke-sitare" class="py-5 bg-white">
  <div class="container">
    <h2 class="text-center mb-5 fw-bold text-success">🌟 गाँव के सितारे 🌟</h2>
    <div class="row g-4">

      <!-- Star 1: NSG Commando -->
