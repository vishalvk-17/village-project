<%- layout("/layouts/boilerplate") %>

<main class="container my-5">
  <% if (!isMongoConnected) { %>
    <div class="alert alert-warning border-0 shadow-sm mb-4">
      Village data service is temporarily unavailable. Basic pages are still live, and full records will return once the database connection is restored.
    </div>
  <% } %>

  <section class="mb-5">
    <h2 class="section-title">About Our Village</h2>
    <div class="row align-items-center g-4">
      <div class="col-md-6">
        <p class="lead">
          Hamara gaon parampara, samudaay aur paraspar sahyog ki pehchaan hai. Is portal ka purpose gaon ke logon,
          notices aur gaon ke gaurav ko ek jagah par lana hai taaki sab kuch digital tareeke se manage ho sake.
        </p>
      </div>
      <div class="col-md-6">
        <img
          src="https://images.unsplash.com/photo-1591883093451-83abd0f56a1f?q=80&w=1170&auto=format&fit=crop"
          alt="Village"
          class="img-fluid rounded shadow"
        >
      </div>
    </div>
  </section>

  <section class="home-insight-strip mb-5">
    <div class="row g-3">
      <div class="col-md-3 col-6">
        <div class="home-insight-card">
          <strong>Digital Identity</strong>
          <span>Gaon ke logon aur parivaron ka structured record</span>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="home-insight-card">
          <strong>Community Reach</strong>
          <span>Residents aur visitors dono ke liye simple public access</span>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="home-insight-card">
          <strong>Admin Control</strong>
          <span>Approvals, notices aur highlights ek jagah manage</span>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="home-insight-card">
          <strong>Future Ready</strong>
          <span>Village data ko modern aur organized format mein rakhna</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-5">
    <h2 class="section-title">Village People Portal</h2>
    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 home-feature-card">
          <div class="card-body text-center">
            <i class="bi bi-person-plus-fill fs-1 text-primary"></i>
            <h5 class="card-title mt-3">Register Profiles</h5>
            <p class="card-text">Gaon ke log apni details, profession aur photo ke saath profile bana sakte hain.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 home-feature-card">
          <div class="card-body text-center">
            <i class="bi bi-grid-3x3-gap-fill fs-1 text-success"></i>
            <h5 class="card-title mt-3">Public Directory</h5>
            <p class="card-text">Approved villagers card-wise dikhte hain jisse gaon ke log ek dusre ko jaan sakein.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 home-feature-card">
          <div class="card-body text-center">
            <i class="bi bi-shield-check fs-1 text-danger"></i>
            <h5 class="card-title mt-3">Admin Approval</h5>
            <p class="card-text">Admin profile approve karta hai aur important homepage content ko bhi manage kar sakta hai.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 home-feature-card">
          <div class="card-body text-center">
            <i class="bi bi-people-fill fs-1 text-warning"></i>
            <h5 class="card-title mt-3">Family Directory</h5>
            <p class="card-text">Har parivar ka dedicated record rakhiye jahan address aur linked members ek saath mil jaayen.</p>
            <a href="/families" class="btn btn-outline-dark btn-sm mt-2">Explore Families</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-process-section mb-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <h2 class="section-title mb-0">How The Portal Works</h2>
      <a href="/register" class="btn btn-outline-primary btn-sm">Start With Registration</a>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="home-process-card h-100">
          <span class="home-process-card__step">01</span>
          <h5>Create Your Profile</h5>
          <p>Villager apni basic details, education, profession aur photo ke saath profile bana sakta hai.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="home-process-card h-100">
          <span class="home-process-card__step">02</span>
          <h5>Admin Verification</h5>
          <p>Approval ke baad public directory mein records safe aur trusted tareeke se show hote hain.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="home-process-card h-100">
          <span class="home-process-card__step">03</span>
          <h5>Community Discovery</h5>
          <p>Visitors villagers, families, notices aur village highlights ko ek hi experience mein explore karte hain.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-5">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <h2 class="section-title mb-0">Notice Board</h2>
      <% if (currentUser && currentUser.role === "admin") { %>
        <a href="/admin" class="btn btn-outline-primary btn-sm">Manage Notices</a>
      <% } %>
    </div>

    <div class="notice-board">
      <% if (notices && notices.length) { %>
        <% for (let notice of notices) { %>
          <div class="notice-item">
            <i class="<%= notice.iconClass || 'bi bi-megaphone text-primary' %>"></i>
            <strong class="ms-2"><%= notice.title %></strong>
            <p class="mb-0 mt-2"><%= notice.description %></p>
          </div>
        <% } %>
      <% } else { %>
        <div class="notice-item">
          <i class="bi bi-megaphone text-primary"></i>
          <strong class="ms-2">No notices available</strong>
          <p class="mb-0 mt-2">Admin dashboard se notices add karne ke baad yahan automatically show honge.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="home-services-section mb-5 mt-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-5">
        <span class="home-section-tag">Village Value</span>
        <h2 class="section-title text-start mb-3">Ek simple portal jo real community problems ko solve karta hai</h2>
        <p class="lead mb-0">
          Information ko scattered rehne dene ke bajay, yeh website village records, public discovery aur admin updates ko ek clean digital experience mein convert karti hai.
        </p>
      </div>
      <div class="col-lg-7">
        <div class="row g-3">
          <div class="col-sm-6">
            <div class="home-mini-panel">
              <i class="bi bi-search"></i>
              <h5>Easy Search</h5>
              <p>Name, village aur profession ke basis par villagers ko fast browse kiya ja sakta hai.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="home-mini-panel">
              <i class="bi bi-house-heart"></i>
              <h5>Family Mapping</h5>
              <p>Household-wise records village ko aur zyada meaningful aur organized banate hain.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="home-mini-panel">
              <i class="bi bi-megaphone"></i>
              <h5>Notice Visibility</h5>
              <p>Important announcements homepage par hi clearly visible rehte hain.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="home-mini-panel">
              <i class="bi bi-award"></i>
              <h5>Village Pride</h5>
              <p>Gaon ke sitare aur achievements ko highlight karke stronger local identity banti hai.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="gaon-ke-sitare" class="py-4 bg-white">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
      <h2 class="section-title mb-0">Gaon Ke Sitare</h2>
      <% if (currentUser && currentUser.role === "admin") { %>
        <a href="/admin" class="btn btn-outline-success btn-sm">Manage Stars</a>
      <% } %>
    </div>

    <div class="row g-4">
      <% if (stars && stars.length) { %>
        <% for (let star of stars) { %>
          <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0 home-feature-card">
              <img src="<%= star.imageUrl %>" class="card-img-top" alt="<%= star.title %>">
              <div class="card-body">
                <h5 class="card-title fw-bold <%= star.accentClass || 'text-primary' %>"><%= star.title %></h5>
                <p class="fw-semibold mb-2"><%= star.name %></p>
                <p class="card-text"><%= star.description %></p>
              </div>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <div class="col-12">
          <div class="alert alert-light border text-center mb-0">
            Abhi gaon ke sitare add nahi hue hain. Admin panel se add karne ke baad yahan dikhne lagenge.
          </div>
        </div>
      <% } %>
    </div>
  </section>

  <section class="mb-5 mt-5">
    <h2 class="section-title">Culture & Traditions</h2>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100 shadow-sm home-feature-card">
          <img src="https://plus.unsplash.com/premium_photo-1682090882077-31b6875e8822?q=80&w=998&auto=format&fit=crop" class="card-img-top" alt="Festival">
          <div class="card-body">
            <h5 class="card-title">Festivals</h5>
            <p class="card-text">Hamare gaon me tyohar mil-jul kar bade utsaah ke saath manaye jaate hain.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm home-feature-card">
          <img src="https://images.unsplash.com/photo-1723066217456-cf0b10ceda2b?q=80&w=1035&auto=format&fit=crop" class="card-img-top" alt="Food">
          <div class="card-body">
            <h5 class="card-title">Traditional Food</h5>
            <p class="card-text">Local khaana aur paramparik swad gaon ki pehchaan ka important hissa hain.</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm home-feature-card">
          <img src="https://images.unsplash.com/photo-1717011969223-0217a302ec6f?q=80&w=986&auto=format&fit=crop" class="card-img-top" alt="Dance">
          <div class="card-body">
            <h5 class="card-title">Folk Culture</h5>
            <p class="card-text">Geet, bhajan aur lok parampara gaon ki samudaayik pehchaan ko mazboot banate hain.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
