<%- layout("/layouts/boilerplate") %>

<!-- New design -->

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <h3 class="text-center mb-4 fw-bold text-primary">
            Update Your Information
          </h3>
          <hr>

          <!-- Profile Image Preview (optional) -->
          <% if(user.image && user.image.url) { %>
            <div class="text-center mb-4">
              <img src="<%= user.image.url %>" alt="Profile Image" 
                   class="rounded-circle shadow" 
                   width="120" height="120"
                   style="object-fit: cover;">
            </div>
          <% } %>

          <!-- Update Form -->
          <form method="POST" action="/<%= user._id %>?_method=PUT" enctype="multipart/form-data">
            <div class="mb-3">
              <label for="name" class="form-label">Full Name</label>
              <input type="text" class="form-control" id="name" name="name" 
                     placeholder="Enter your name" value="<%= user.name %>">
            </div>

            <div class="mb-3">
              <label for="age" class="form-label">Age</label>
              <input type="number" class="form-control" id="age" name="age" 
                     placeholder="Enter your age" value="<%= user.age %>">
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email Address</label>
              <input type="email" class="form-control" id="email" name="email" 
                     placeholder="Enter your email" value="<%= user.email %>">
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" 
                     name="password" placeholder="Update password">
              <small class="text-muted">Leave blank if you don’t want to change it</small>
            </div>

            <div class="mb-3">
              <label for="image" class="form-label">Profile Image</label>
              <input type="file" class="form-control" id="image" name="image" accept="image/*">
            </div>

            <div class="d-grid mt-4">
              <button type="submit" class="btn btn-primary btn-lg">
                Update Information
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>



