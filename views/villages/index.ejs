<%- layout("/layouts/boilerplate") %>
<body>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <!-- Card for Register Form -->
        <div class="card shadow-lg border-0 rounded-4">
          <div class="card-body p-4">
            <h2 class="text-center mb-3">Register Here</h2>
            <p class="text-muted text-center mb-4">Fill the details below to register yourself</p>
            <hr>

            <form action="/register" method="post" enctype="multipart/form-data">
              <!-- Name -->
              <div class="mb-3">
                <label for="name" class="form-label fw-bold">Name</label>
                <input type="text" placeholder="Enter your name" name="name" class="form-control" required>
              </div>

              <!-- Age -->
              <div class="mb-3">
                <label for="age" class="form-label fw-bold">Age</label>
                <input type="number" placeholder="Enter your age" name="age" class="form-control" required>
              </div>

              <!-- Email -->
              <div class="mb-3">
                <label for="email" class="form-label fw-bold">Email</label>
                <input type="email" placeholder="Enter your email" name="email" class="form-control" required>
              </div>

              <!-- Password -->
              <div class="mb-3">
                <label for="password" class="form-label fw-bold">Password</label>
                <input type="password" placeholder="Enter password" name="password" class="form-control" required>
              </div>

              <!-- Image Upload -->
              <div class="mb-3">
                <label for="image" class="form-label fw-bold">Profile Photo</label>
                <input type="file" name="image" accept="image/*" class="form-control">
              </div>

              <!-- Submit Button -->
              <div class="d-grid mt-4">
                <button class="btn btn-primary btn-lg shadow-sm">Submit</button>
              </div>
            </form>
          </div>
        </div>

        <!-- Small Note -->
        <p class="text-center text-muted mt-3">
          Already registered? <a href="/login" class="text-decoration-none">Login here</a>
        </p>
      </div>
    </div>
  </div>
</body>

