<%- layout("/layouts/boilerplate") %>

<section class="villagers-directory py-5">
  <div class="text-center mb-5">
    <h2 class="mb-2">Village People Directory</h2>
    <p class="text-muted mb-0">See the people of the village, what they do, and learn a little about them.</p>
  </div>

  <form action="/villagers" method="GET" class="card border-0 shadow-sm p-3 p-md-4 mb-4 villager-filter-form">
    <div class="row g-3 align-items-end">
      <div class="col-md-6">
        <label for="search" class="form-label">Search Villagers</label>
        <input
          type="text"
          id="search"
          name="search"
          value="<%= search || '' %>"
          class="form-control"
          placeholder="Search by name, village or profession"
        >
      </div>

      <div class="col-md-4">
        <label for="profession" class="form-label">Filter by Profession</label>
        <select id="profession" name="profession" class="form-select">
          <option value="">All professions</option>
          <% for (let item of professions) { %>
            <option value="<%= item %>" <%= profession === item ? "selected" : "" %>><%= item %></option>
          <% } %>
        </select>
      </div>

      <div class="col-md-2 d-grid">
        <button class="btn btn-primary">Apply</button>
      </div>
    </div>
  </form>

  <% if (users.length === 0) { %>
    <div class="alert alert-warning text-center shadow-sm">
      No villagers found for this search. Try another name or profession.
    </div>
  <% } else { %>
    <div class="row g-4">
      <% for (let user of users) { %>
        <div class="col-lg-4 col-md-6">
          <div class="card h-100 border-0 shadow villager-card">
            <div class="card-body p-4 text-center">
              <img
                src="<%= user.imageData ? `data:${user.imageType};base64,${user.imageData}` : 'https://placehold.co/160x160?text=User' %>"
                alt="<%= user.name %>"
                class="villager-card__avatar mx-auto mb-3"
              >
              <h4 class="mb-1"><%= user.name %></h4>
              <p class="villager-card__profession mb-2"><%= user.profession || "Profession not added" %></p>

              <% if (currentUser && currentUser.role === "admin" && user.isApproved === false) { %>
                <span class="badge text-bg-warning mb-3">Pending Approval</span>
              <% } %>

              <div class="villager-card__meta text-start">
                <p><strong>Age:</strong> <%= user.age || "N/A" %></p>
                <p><strong>Village:</strong> <%= user.village || "Bhilkheda" %></p>
                <p><strong>Education:</strong> <%= user.education || "N/A" %></p>
                <% if (currentUser && (currentUser.role === "admin" || currentUser.id === user._id.toString())) { %>
                  <p><strong>Email:</strong> <%= user.email %></p>
                  <p><strong>Phone:</strong> <%= user.phone || "N/A" %></p>
                <% } else { %>
                  <p class="text-muted small mb-0">Phone and email are private for public visitors.</p>
                <% } %>
              </div>

              <% if (user.about) { %>
                <p class="text-muted small mt-3 mb-4"><%= user.about.length > 120 ? `${user.about.slice(0, 120)}...` : user.about %></p>
              <% } %>

              <div class="d-grid gap-2">
                <a href="/<%= user._id %>" class="btn btn-outline-primary w-100">View Full Profile</a>
                <% if (currentUser && currentUser.role === "admin" && user.isApproved === false) { %>
                  <form action="/<%= user._id %>/approve" method="POST">
                    <button class="btn btn-success w-100" type="submit">Approve Profile</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</section>
