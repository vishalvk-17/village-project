<%- layout("/layouts/boilerplate") %>
<!-- New style -->
<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h3 class="text-center mb-4">User Information</h3>
      <div class="card shadow-lg border-0 rounded-3">
        
        <!-- Profile Image -->
        <div class="text-center mt-4">
          <img src="/uploads/<%= user.image %>" 
               class="rounded-circle img-fluid shadow-sm" 
               alt="user-img"
               style="width: 150px; height: 150px; object-fit: cover;">
        </div>

        <div class="card-body text-center">
          <!-- User Info -->
          <h5 class="card-title mt-3"><%= user.name %></h5>
          <p class="text-muted mb-1">Age: <%= user.age %></p>
          <p class="text-muted">Email: <%= user.email %></p>

          <!-- Buttons -->
          <div class="d-flex justify-content-center gap-3 mt-4">
            <% if (currentUser && (currentUser.role === 'admin' || currentUser.id === user._id.toString())) { %>
              <a href="/<%= user._id %>/edit" class="btn btn-primary">Update</a>

              <form action="/<%= user._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>







