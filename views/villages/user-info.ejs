<%- layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-body p-4 p-md-5">
          <div class="text-center">
            <img
              src="<%= user.imageData ? `data:${user.imageType};base64,${user.imageData}` : 'https://placehold.co/180x180?text=User' %>"
              class="rounded-circle img-fluid shadow-sm mb-3"
              alt="user-img"
              style="width: 180px; height: 180px; object-fit: cover;"
            >
            <h3 class="mb-1"><%= user.name %></h3>
            <p class="text-primary fw-semibold mb-3"><%= user.profession || "Profession not added" %></p>
            <% if (user.isApproved === false) { %>
              <span class="badge text-bg-warning mb-4">Waiting For Admin Approval</span>
            <% } %>
          </div>

          <div class="row g-3 villager-profile-details">
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Age</span>
                <strong><%= user.age || "N/A" %></strong>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Gender</span>
                <strong><%= user.gender || "N/A" %></strong>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Email</span>
                <strong><%= currentUser && (currentUser.role === "admin" || currentUser.id === user._id.toString()) ? user.email : "Private for public visitors" %></strong>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Phone</span>
                <strong><%= currentUser && (currentUser.role === "admin" || currentUser.id === user._id.toString()) ? (user.phone || "N/A") : "Private for public visitors" %></strong>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Village</span>
                <strong><%= user.village || "Bhilkheda" %></strong>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-detail-box">
                <span>Education</span>
                <strong><%= user.education || "N/A" %></strong>
              </div>
            </div>
            <div class="col-12">
              <div class="profile-detail-box">
                <span>About</span>
                <strong><%= user.about || "No additional details added yet." %></strong>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <% if (currentUser && currentUser.role === "admin" && user.isApproved === false) { %>
              <form action="/<%= user._id %>/approve" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-success">Approve Profile</button>
              </form>
            <% } %>

            <% if (currentUser && (currentUser.role === "admin" || currentUser.id === user._id.toString())) { %>
              <a href="/<%= user._id %>/edit" class="btn btn-primary">Update</a>

              <form action="/<%= user._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
